# ===========================================
# AGENCYBOT CHATBOT — ENVIRONMENT VARIABLES
# ===========================================
# Copy to .env and fill in real values before running.
# Anything marked "required" must be set; everything else has a sensible default.

# Docker Compose project name (used for container/volume naming)
COMPOSE_PROJECT_NAME=agencybot

# Application
APP_NAME=agencybot
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# ===========================================
# DATABASE
# ===========================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agencybot
POSTGRES_USER=agencybot_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
# Required: generate with: openssl rand -hex 16
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Cache TTL (seconds)
CACHE_TTL_SERVICES=3600
CACHE_TTL_STYLISTS=3600
CACHE_TTL_INFO=3600

# ===========================================
# OPENAI
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# ===========================================
# CHATWOOT
# ===========================================
CHATWOOT_BASE_URL=https://your-chatwoot-instance.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token_here
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# Webhook authentication (at least one required in production)
# Option 1: URL token — append ?token=VALUE to the webhook URL in Chatwoot
CHATWOOT_WEBHOOK_TOKEN=generate_a_random_token_here
# Option 2: HMAC signature — if your Chatwoot supports X-Chatwoot-Signature
# CHATWOOT_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# GOOGLE CALENDAR
# ===========================================
# Path to Google service account credentials JSON file
GOOGLE_CREDENTIALS_PATH=/app/credentials/google_service_account.json

# Calendar ID (usually the email of the calendar)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Timezone for calendar operations
CALENDAR_TIMEZONE=America/Mexico_City

# ===========================================
# GOOGLE DRIVE (for backups)
# ===========================================
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# Days to keep backups in Google Drive (older ones are auto-deleted)
BACKUP_RETENTION_DAYS=30

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_MAX_MESSAGES=30
RATE_LIMIT_WINDOW_SECONDS=3600

# Message grouping delay (seconds)
MESSAGE_GROUP_DELAY=3

# Notify owner when a user gets rate-limited (true/false)
RATE_LIMIT_NOTIFY_OWNER=true

# ===========================================
# HUMAN HANDOFF
# ===========================================
# Chatwoot status to set when escalating (open, pending, snoozed)
HANDOFF_CHATWOOT_STATUS=pending
# Label added to escalated conversations
HANDOFF_LABEL=atencion-humana
# Cooldown (seconds) between "an agent will help you" replies while bot is paused
PAUSED_REPLY_COOLDOWN_SECONDS=300

# ===========================================
# BOOKING CONSTRAINTS
# ===========================================
# Max active (future, pendiente/confirmada) appointments per phone number (0 = unlimited)
MAX_ACTIVE_APPOINTMENTS_PER_USER=3

# ===========================================
# SCHEDULED JOBS
# ===========================================
# Owner's phone number for weekly reports (with country code, e.g., 521234567890)
OWNER_PHONE_NUMBER=521234567890

# Weekly report day (0=Monday, 6=Sunday)
WEEKLY_REPORT_DAY=0
WEEKLY_REPORT_HOUR=9
WEEKLY_REPORT_MINUTE=0

# Daily reminders time
DAILY_REMINDER_HOUR=18
DAILY_REMINDER_MINUTE=0

# Daily backup time
DAILY_BACKUP_HOUR=3
DAILY_BACKUP_MINUTE=0

# Calendar sync interval (minutes)
CALENDAR_SYNC_INTERVAL_MINUTES=15

# ===========================================
# BUSINESS IDENTITY
# ===========================================
SALON_NAME=AgencyBot
SALON_ADDRESS=
SALON_PHONE=
SALON_HOURS=Lunes a Viernes: 9:00 AM - 6:00 PM
# Type of business (used in system prompt and image analysis)
BUSINESS_TYPE=agencia de consultoría en IA
# Currency symbol for prices
CURRENCY_SYMBOL=$
# Audio transcription language (ISO 639-1 code)
WHISPER_LANGUAGE=es

# ===========================================
# AGENT BEHAVIOR
# ===========================================
AGENT_TIMEOUT_SECONDS=120
AGENT_TEMPERATURE=0.3
AGENT_MAX_ITERATIONS=10
AGENT_HISTORY_LIMIT=10
CONVERSATION_CONTEXT_LIMIT=20
CONVERSATION_CONTEXT_TTL=3600

# Default business hours for availability checks
DEFAULT_BUSINESS_START_HOUR=9
DEFAULT_BUSINESS_END_HOUR=20
DEFAULT_SLOT_INTERVAL=30

# ===========================================
# CUSTOMIZABLE MESSAGES (empty = use built-in defaults)
# ===========================================
# BOT_PAUSED_MESSAGE=
# HANDOFF_MESSAGE=
# RATE_LIMIT_MESSAGE=
# AGENT_TIMEOUT_MESSAGE=
# AGENT_ERROR_MESSAGE=

# ===========================================
# SYSTEM PROMPT (empty = use built-in template)
# ===========================================
# Full override for the agent system prompt
# SYSTEM_PROMPT_OVERRIDE=
# Override for image analysis prompt
# VISION_PROMPT_OVERRIDE=

# ===========================================
# SEED DATA
# ===========================================
# Set to false for new client deployments (populate via DB instead)
SEED_DATA_ENABLED=true

# Redis key prefix (change per instance if sharing Redis)
REDIS_KEY_PREFIX=agencybot

# ===========================================
# TELEGRAM ERROR NOTIFICATIONS (optional)
# ===========================================
# Bot token from @BotFather — leave empty to disable Telegram alerts
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Chat/group/channel ID to receive alerts
# TELEGRAM_CHAT_ID=-1001234567890
# Deduplication window in seconds (same error won't be sent again within this time)
TELEGRAM_ALERT_COOLDOWN_SECONDS=300

# ===========================================
# ADMIN PANEL
# ===========================================
# Username for the initial admin user (created on first startup)
ADMIN_USERNAME=admin
# Password for the initial admin user (leave empty to skip auto-creation)
# MUST be at least 12 chars with uppercase, lowercase, digit, and special char
ADMIN_PASSWORD=

# ===========================================
# SECURITY
# ===========================================
# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=*
